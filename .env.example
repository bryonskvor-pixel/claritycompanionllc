# Clarity Companion — server-side environment variables
# Copy to Vercel → Project → Settings → Environment Variables.
# NONE of these ever appear in client code.

# --- Email (contact form + discovery briefs) ---
# Create a key at https://resend.com → API Keys
RESEND_API_KEY=
# Where inquiries and briefs are delivered. CONFIRM WITH OWNER — if
# bryon@claritycompanionllc.com has no mailbox yet, that's a setup task.
CONTACT_TO_EMAIL=bryon@claritycompanionllc.com
# Must be on a domain verified in Resend. Until claritycompanionllc.com is
# verified there, leave unset to fall back to onboarding@resend.dev
# (delivers only to the Resend account owner's address).
CONTACT_FROM_EMAIL=

# --- C.C. discovery chat (Phase 2) ---
# Server-side only. Never ship this to the browser.
ANTHROPIC_API_KEY=

# --- Brief/session storage (Phase 2) ---
# Vercel KV / Upstash Redis REST credentials. Optional: without them, briefs
# still email but aren't persisted and durable rate limits are skipped.
# The Vercel Storage integration injects credentials automatically when you
# connect the database to the project. Any ONE of these shapes works:
#   REST (Upstash/KV): KV_REST_API_URL + KV_REST_API_TOKEN (or UPSTASH_REDIS_REST_*)
#   Direct (Redis Cloud integration): REDIS_URL connection string
KV_REST_API_URL=
KV_REST_API_TOKEN=
REDIS_URL=

# --- Observability (Phase 2) ---
# Daily Claude spend ceiling in USD; Track A auto-disables above it.
DAILY_SPEND_CEILING_USD=5
# Shared secret protecting the daily-summary cron endpoint. Vercel sends it
# automatically as "Authorization: Bearer <CRON_SECRET>" when set.
CRON_SECRET=
